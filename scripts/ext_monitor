#!/bin/sh

ext_monitor=$(xrandr --query | rg 'DP-2')
if [[ $ext_monitor = *connected* ]]; then
	  xrandr --output DP-2 --primary --mode 5120x1440 --scale 1.5 --rotate normal --output DP-1 --mode 3440x1440 --scale 1.5 --rotate left --right-of DP-2
	  xrandr --output DP-1 --pos 7680x-1080
	  xrandr --output eDP-1 --off
fi
